# Puedes poner este archivo como `.env` en la raíz de `surveyapp/`
# y/o copiar las claves a `server/.env` (server tiene prioridad si repites claves).

# --- Servidor local (Express) ---
PORT=3001
NODE_ENV=development

# --- Supabase (backend: mismo proyecto que la URL pública) ---
# URL del proyecto: Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Anon key: para cliente o servidor con RLS bien configurado
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Recomendado solo en servidor (Vercel / .env local): bypass RLS para API propia
# Nunca expongas esta clave en el frontend ni en VITE_*
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend (Vite): prefijo VITE_ ---
# Vacío en desarrollo: el proxy de Vite envía /api al backend (puerto 3001)
# En preview o build estático sin proxy, pon la URL base del API, p. ej. https://tu-app.vercel.app
VITE_API_URL=
